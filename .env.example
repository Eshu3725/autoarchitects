# Supabase Configuration
# Get these values from your Supabase project dashboard at https://app.supabase.com

# Your Supabase project URL (e.g., https://xxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=your_supabase_url_here

# Your Supabase anonymous/public key (safe to use in client-side code)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Note: Create a .env file in the root directory and copy these variables
# Replace the placeholder values with your actual Supabase credentials
# DO NOT commit the .env file to version control (it's in .gitignore)

